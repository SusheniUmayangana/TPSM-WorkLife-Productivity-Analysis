# 2. Obtain the following for each variable
# a. Box-Plot, Histogram and Stem-Leaf Plot.
# Setup plotting area for histograms and boxplots
par(mfrow=c(1,2))
variables <- list(Attendance=X1_Attendance, Salary=X2_Salary, Years=X3_Years)
for(name in names(variables)) {
# Boxplot
boxplot(variables[[name]], main=paste("Boxplot of", name), col="lightblue")
# Histogram
hist(variables[[name]], main=paste("Histogram of", name), col="lightgreen", xlab=name)
# Stem and Leaf (Prints to console)
cat("\nStem and Leaf Plot for", name, ":\n")
stem(variables[[name]])
}
# Mean
mean_attendance = mean(mlb_data$X1_Attendance)
mean_salary = mean(mlb_data$X2_Salary)
mean_years = mean(mlb_data$X3_Years)
# Median
med_attendance = median(mlb_data$X1_Attendance)
med_salary = median(mlb_data$X2_Salary)
med_years = median(mlb_data$X3_Years)
# Standard Deviation
sd_attendance = sd(mlb_data$X1_Attendance)
sd_salary = sd(mlb_data$X2_Salary)
sd_years = sd(mlb_data$X3_Years)
# Display results
cat("Attendance - Mean:", mean_attendance, "Median:", med_attendance, "SD:", sd_attendance, "\n")
cat("Salary     - Mean:", mean_salary, "Median:", med_salary, "SD:", sd_salary, "\n")
cat("Years      - Mean:", mean_years, "Median:", med_years, "SD:", sd_years, "\n")
# First Quartile (Q1)
q1_attendance = quantile(mlb_data$X1_Attendance, 0.25)
q1_salary = quantile(mlb_data$X2_Salary, 0.25)
q1_years = quantile(mlb_data$X3_Years, 0.25)
# Third Quartile (Q3)
q3_attendance = quantile(mlb_data$X1_Attendance, 0.75)
q3_salary = quantile(mlb_data$X2_Salary, 0.75)
q3_years = quantile(mlb_data$X3_Years, 0.75)
# Display results
cat("Attendance - Q1:", q1_attendance, "| Q3:", q3_attendance, "\n")
cat("Salary     - Q1:", q1_salary, "| Q3:", q3_salary, "\n")
cat("Years      - Q1:", q1_years, "| Q3:", q3_years, "\n")
# Calculating IQR
iqr_attendance = IQR(mlb_data$X1_Attendance)
iqr_salary = IQR(mlb_data$X2_Salary)
iqr_years = IQR(mlb_data$X3_Years)
# Display results
cat("Attendance IQR:", iqr_attendance, "\n")
cat("Salary IQR:    ", iqr_salary, "\n")
cat("Years IQR:     ", iqr_years, "\n")
find_modes = function(v) {
uniqv = unique(v)
freq = tabulate(match(v, uniqv))
uniqv[freq == max(freq)]
}
# Checking the mode for "Years" (X3)
cat("Mode(s) for Years:", find_modes(mlb_data$X3_Years))
find_outliers = function(v) {
q1 = quantile(v, 0.25)
q3 = quantile(v, 0.75)
iqr_val = IQR(v)
lower_bound = q1 - 1.5 * iqr_val
upper_bound = q3 + 1.5 * iqr_val
outliers = v[v < lower_bound | v > upper_bound]
if(length(outliers) == 0) {
return("No outliers detected")
} else {
return(outliers)
}
}
# Checking all three variables
list(
Attendance_Outliers = find_outliers(mlb_data$X1_Attendance),
Salary_Outliers = find_outliers(mlb_data$X2_Salary),
Years_Outliers = find_outliers(mlb_data$X3_Years)
)
